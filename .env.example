# development | production (padrão seguro: production se omitido após carregar .env)
APP_ENV=development

# URL pública do site (links de compartilhamento de atividades). Ex.:
# APP_URL=https://dchub.seudominio.br
# Em dev, se omitido, usa o host da requisição (localhost, etc.).
APP_URL=

# Fuso para lembretes matinais e datas do cron (padrão: America/Sao_Paulo)
APP_TIMEZONE=America/Sao_Paulo

# sqlite (padrão local) | mysql (produção)
DB_DRIVER=sqlite
DB_PATH=database/dc_hub.sqlite

# MySQL/MariaDB (descomente e defina DB_DRIVER=mysql)
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=dc_hub
# DB_USER=root
# DB_PASS=

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@dchub.local
SMTP_PASS=
SMTP_FROM=noreply@dchub.local
SMTP_FROM_NAME="DC Hub"

# Máximo de e-mails de lembrete por dia (APP_TIMEZONE). Recuperação de senha não usa esta cota.
REMINDER_EMAIL_DAILY_LIMIT=50

# Planejamento: horizonte e antecedência máxima (1 lembrete por inscrição, digest por usuário)
REMINDER_PLANNING_HORIZON_DAYS=7
REMINDER_MAX_LEAD_DAYS=7
