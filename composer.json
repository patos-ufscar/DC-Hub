{
    "name": "patos-ufscar/dc-hub",
    "description": "Calendário e gestão de atividades — DC/UFSCar (PATOS)",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-clover build/coverage/clover.xml"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {}
    }
}
